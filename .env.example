# Your agent's name (shown in trust checks and agent card)
AGENT_NAME=my-trusted-agent

# Server port
PORT=3000

# Your agent's public URL
BASE_URL=http://localhost:3000

# Your agent's wallet address (register at https://agentstamp.org)
WALLET_ADDRESS=

# AgentStamp API (default: production — override for self-hosted)
# AGENTSTAMP_API_URL=https://agentstamp.org/api/v1
